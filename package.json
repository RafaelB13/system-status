{
  "name": "system-status",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "start": "tsc && tsc-alias && electron .",
    "build": "tsc && tsc-alias",
    "dist": "tsc && tsc-alias && electron-builder"
  },
  "build": {
    "appId": "com.rafael.systemstatus",
    "productName": "System Status",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "artifactName": "System-Status-${version}.${ext}",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RafaelB13/system-status.git"
  },
  "bugs": {
    "url": "https://github.com/RafaelB13/system-status/issues"
  },
  "homepage": "https://github.com/RafaelB13/system-status#readme",
  "type": "commonjs",
  "dependencies": {
    "os-utils": "^0.0.14"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/os-utils": "^0.0.4",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.0",
    "ts-loader": "^9.5.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  }
}
